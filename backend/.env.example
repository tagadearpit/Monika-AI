# ─────────────────────────────────────────────────────────────────────────────
# Runtime
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=10000
DEFAULT_TIME_ZONE=Asia/Kolkata
LOG_ALL_REQUESTS=false

# ─────────────────────────────────────────────────────────────────────────────
# Required core services
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=replace_with_primary_gemini_key
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FACT_MODEL=gemini-2.5-flash-lite
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/monika-ai

# Generate both secrets independently with at least 32 random characters.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
OTP_SECRET=replace_with_a_different_long_random_secret

# Exact frontend origins, comma-separated. Never use * in production.
# Do not include trailing slashes.
ALLOWED_ORIGINS=http://localhost:10000,https://your-domain.example

# ─────────────────────────────────────────────────────────────────────────────
# Persistent session policy
# ─────────────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=900
SESSION_TTL_DAYS=365
MAX_SESSIONS_PER_USER=10
LOGIN_NOTIFICATION_EMAILS=false

# ─────────────────────────────────────────────────────────────────────────────
# API limits and MongoDB pool
# ─────────────────────────────────────────────────────────────────────────────
ASK_RATE_LIMIT=100
AUTH_RATE_LIMIT=15
MAX_DAILY_MESSAGES=250
MAX_DAILY_IMAGES=30
MAX_ATTACHMENT_BYTES=8388608
MAX_TOTAL_ATTACHMENT_BYTES=16777216
# Optional operational estimate; set this from your current Gemini pricing.
ESTIMATED_COST_PER_MILLION_TOKENS_USD=0
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=1

# ─────────────────────────────────────────────────────────────────────────────
# Administration
# Comma-separated verified email accounts. Leave empty to disable the dashboard.
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=

# ─────────────────────────────────────────────────────────────────────────────
# Google Identity Services
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─────────────────────────────────────────────────────────────────────────────
# Firebase browser configuration
# ─────────────────────────────────────────────────────────────────────────────
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Recommended for production phone-auth revocation checks.
# Store the complete service-account JSON as one environment-variable value.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CHECK_REVOKED=false

# ─────────────────────────────────────────────────────────────────────────────
# Email OTP and optional login notifications
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@your-domain.example

# ─────────────────────────────────────────────────────────────────────────────
# Optional Web Push notifications for reminders
# Generate with: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@your-domain.example
